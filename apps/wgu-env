  #
  # # Close specific Dev Apps
  # pkill -9 "Bitwarden"
  # pkill -9 "kitty" #
  # pkill -9 "nvim"  #

  pkill -9 ssh-agent 2>/dev/null
  pkill -9 language-server 2>/dev/null

  sudo pkill -9 docker 2>/dev/null
  sudo launchctl load $NIX_DAEMON_PLIST
  sudo launchctl load $REMOTE_PLIST

  echo "Run \`:lsp stop\` or \`:LspStop\` in Vim"

  echo "System cleaned. Run 'ps aux | grep -E \"tailscale|qemu|python\"' to verify."

  exit 0
fi
