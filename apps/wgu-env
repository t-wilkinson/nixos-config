#!/bin/sh -e

NIX_DAEMON_PLIST="/Library/LaunchDaemons/org.nixos.nix-daemon.plist"
REMOTE_PLIST="/System/Library/LaunchDaemons/com.apple.remotemanagement.remotectl.plist"
if [ "$1" = "restore" ]; then
  sudo launchctl load $NIX_DAEMON_PLIST
  sudo launchctl load $REMOTE_PLIST
  echo "Run \`:lsp start\` or \`:LspStart\` in Vim"
  exit 0
fi

if [ "$1" = "clear" ]; then
  # echo "Stopping high-risk ProctorU triggers..."
